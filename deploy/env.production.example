# Copy this file to .env.production on the server and fill ВСТАВЬ_СЮДА values.

NODE_ENV="production"
CABINET_DOMAIN="ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА"
CABINET_ENABLE_CADDY="true"
CABINET_APP_BIND="127.0.0.1"
CABINET_APP_PORT="3000"
CABINET_EXTERNAL_NETWORK="remnawave-network"

# Built-in PostgreSQL container
POSTGRES_DB="cabinet"
POSTGRES_USER="cabinet"
POSTGRES_PASSWORD="ВСТАВЬ_СЮДА_СИЛЬНЫЙ_ПАРОЛЬ_БД"
DATABASE_URL="postgresql://cabinet:ВСТАВЬ_СЮДА_СИЛЬНЫЙ_ПАРОЛЬ_БД@db:5432/cabinet?schema=public"

# Cabinet public URL
APP_URL="https://ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА"
ALLOWED_ORIGINS="https://ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА"

# Generate fresh values on the server:
# openssl rand -hex 32
JWT_SECRET="ВСТАВЬ_СЮДА_JWT_SECRET"
HEALTHCHECK_TOKEN="ВСТАВЬ_СЮДА_HEALTHCHECK_TOKEN"

# Email verification. Must send real email in production.
# Simple built-in option: use https://ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА/api/email/resend
EMAIL_VERIFICATION_WEBHOOK_URL="https://ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА/api/email/resend"
EMAIL_VERIFICATION_WEBHOOK_SECRET="ВСТАВЬ_СЮДА_SECRET_ДЛЯ_EMAIL_WEBHOOK"
RESEND_API_KEY="ВСТАВЬ_СЮДА_RESEND_API_KEY"
EMAIL_FROM="VPN Cabinet <noreply@ВСТАВЬ_СЮДА_ДОМЕН_ПОЧТЫ>"

# Remnawave Panel API
REMNAWAVE_BASE_URL="https://ВСТАВЬ_СЮДА_ДОМЕН_REMNAWAVE"
REMNAWAVE_TOKEN="ВСТАВЬ_СЮДА_REMNAWAVE_API_TOKEN"
REMNAWAVE_INTERNAL_SQUAD_UUIDS="ВСТАВЬ_СЮДА_UUID_SQUAD"

# Optional old remnashop read-only database access
REMNASHOP_DATABASE_URL="postgresql://ВСТАВЬ_СЮДА_READONLY_USER:ВСТАВЬ_СЮДА_READONLY_PASSWORD@ВСТАВЬ_СЮДА_HOST_REMNASHOP:5432/remnashop?schema=public"
REMNASHOP_DATABASE_SSL="true"

# YooKassa production keys
YOOKASSA_SHOP_ID="ВСТАВЬ_СЮДА_SHOP_ID"
YOOKASSA_SECRET_KEY="ВСТАВЬ_СЮДА_БОЕВОЙ_SECRET_KEY"
YOOKASSA_WEBHOOK_URL="https://ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА/api/webhook/yookassa"
YOOKASSA_WEBHOOK_ALLOWED_IPS=""

# Payment worker: checks pending payments and cancels stale ones.
PAYMENT_RECONCILE_INTERVAL_SECONDS="60"
PAYMENT_RECONCILE_BATCH_SIZE="25"
PAYMENT_RECONCILE_MIN_AGE_SECONDS="30"
PAYMENT_CANCEL_PENDING_AFTER_SECONDS="600"

# Telegram is optional. Fill only if old Telegram subscription transfer is needed.
TELEGRAM_CLIENT_ID=""
TELEGRAM_CLIENT_SECRET=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_NOTIFY_CHAT_ID=""
