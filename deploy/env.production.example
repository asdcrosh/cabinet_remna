# Copy this file to .env on the server and fill ВСТАВЬ_СЮДА values.

NODE_ENV="production"
CABINET_IMAGE="ghcr.io/asdcrosh/cabinet_remna:latest"
CABINET_PULL_POLICY="always"
# install-server.sh disables caddy automatically if ports 80/443 are already busy.
COMPOSE_PROFILES="caddy"
CABINET_DOMAIN="ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА"
CABINET_BRAND_NAME="ВСТАВЬ_СЮДА_НАЗВАНИЕ_СЕРВИСА"
CABINET_APP_BIND="127.0.0.1"
# install-server.sh keeps 3000 on a clean server and switches to 3030 if 3000 is busy.
CABINET_APP_PORT="3000"
CABINET_DB_BIND="127.0.0.1"
CABINET_DB_PORT="5433"
CABINET_EXTERNAL_NETWORK="remnawave-network"

# Built-in PostgreSQL container
POSTGRES_DB="cabinet"
POSTGRES_USER="cabinet"
POSTGRES_PASSWORD="ВСТАВЬ_СЮДА_СИЛЬНЫЙ_ПАРОЛЬ_БД"
DATABASE_URL="postgresql://cabinet:ВСТАВЬ_СЮДА_СИЛЬНЫЙ_ПАРОЛЬ_БД@db:5432/cabinet?schema=public"

# Cabinet public URL
APP_URL="https://ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА"
ALLOWED_ORIGINS="https://ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА"

# Generate fresh values on the server:
# openssl rand -hex 32
JWT_SECRET="ВСТАВЬ_СЮДА_JWT_SECRET"
HEALTHCHECK_TOKEN="ВСТАВЬ_СЮДА_HEALTHCHECK_TOKEN"
APP_LOG_LEVEL="info"
APP_REQUEST_LOGS="true"

# Email verification. Must send real email in production.
# Simple built-in option: use https://ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА/api/email/resend
EMAIL_VERIFICATION_WEBHOOK_URL="https://ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА/api/email/resend"
EMAIL_VERIFICATION_WEBHOOK_SECRET="ВСТАВЬ_СЮДА_SECRET_ДЛЯ_EMAIL_WEBHOOK"
RESEND_API_KEY="ВСТАВЬ_СЮДА_RESEND_API_KEY"
EMAIL_FROM="ВСТАВЬ_СЮДА_НАЗВАНИЕ_СЕРВИСА <noreply@ВСТАВЬ_СЮДА_ДОМЕН_ПОЧТЫ>"

# Remnawave Panel API
REMNAWAVE_BASE_URL="https://ВСТАВЬ_СЮДА_ДОМЕН_REMNAWAVE"
REMNAWAVE_TOKEN="ВСТАВЬ_СЮДА_REMNAWAVE_API_TOKEN"
# Optional fallback. Prefer selecting squads per plan in the admin panel.
REMNAWAVE_INTERNAL_SQUAD_UUIDS=""

# Optional old remnashop read-only database access.
# If remnashop-db runs on the same server, install-server.sh auto-detects it.
REMNASHOP_DB_CONTAINER="remnashop-db"
REMNASHOP_DATABASE_URL=""
REMNASHOP_DATABASE_SSL="true"
REMNASHOP_API_URL=""
REMNASHOP_CATALOG_SYNC_INTERVAL_SECONDS="300"
REMNASHOP_USER_SUBSCRIPTION_SYNC_STALE_SECONDS="300"

# Referral bonus after first paid provisioned purchase from invited user
REFERRAL_BONUS_DAYS="7"

# Gift box openings and promo gifts
BONUS_BOX_ENABLED="true"
BONUS_BOX_RUB_PER_ATTEMPT="300"
BONUS_BOX_MIN_ATTEMPTS_PER_PAYMENT="1"
BONUS_BOX_MAX_ATTEMPTS_PER_PAYMENT="10"
BONUS_BOX_ATTEMPT_TTL_DAYS="30"
BONUS_BOX_WEEKLY_ENABLED="true"
# 0 = Sunday, 5 = Friday
BONUS_BOX_WEEKLY_DAY="5"
BONUS_BOX_WEEKLY_ATTEMPTS="1"
BONUS_BOX_WEEKLY_MAX_BALANCE="3"
BONUS_BOX_REFERRER_ATTEMPTS="2"
BONUS_BOX_REFERRED_ATTEMPTS="1"
BONUS_BOX_PROMO_EXPIRES_IN_DAYS="7"
BONUS_BOX_ECONOMY_GUARD_ENABLED="true"
BONUS_BOX_RARE_COOLDOWN_OPENINGS="2"
BONUS_BOX_EPIC_COOLDOWN_OPENINGS="8"
BONUS_BOX_LEGENDARY_COOLDOWN_OPENINGS="30"
BONUS_BOX_EPIC_MIN_OPENINGS="4"
BONUS_BOX_LEGENDARY_MIN_OPENINGS="12"

# YooKassa production keys
YOOKASSA_SHOP_ID="ВСТАВЬ_СЮДА_SHOP_ID"
YOOKASSA_SECRET_KEY="ВСТАВЬ_СЮДА_БОЕВОЙ_SECRET_KEY"
YOOKASSA_WEBHOOK_URL="https://ВСТАВЬ_СЮДА_ДОМЕН_КАБИНЕТА/api/webhook/yookassa"
YOOKASSA_WEBHOOK_ALLOWED_IPS=""

# Payment worker: checks pending payments and cancels stale ones.
PAYMENT_RECONCILE_INTERVAL_SECONDS="60"
PAYMENT_RECONCILE_BATCH_SIZE="25"
PAYMENT_RECONCILE_MIN_AGE_SECONDS="30"
PAYMENT_CANCEL_PENDING_AFTER_SECONDS="600"

# Telegram Web Login is optional.
TELEGRAM_CLIENT_ID=""
TELEGRAM_CLIENT_SECRET=""
TELEGRAM_BOT_USERNAME=""
# Required for automatic authentication when the cabinet is opened as a Telegram Mini App.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_NOTIFY_CHAT_ID=""
