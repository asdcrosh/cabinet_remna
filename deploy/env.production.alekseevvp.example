# Copy this file to .env.production on the server and fill CHANGE_ME values.

NODE_ENV="production"
CABINET_DOMAIN="cabinet.alekseevvp.site"

# Built-in PostgreSQL container
POSTGRES_DB="cabinet"
POSTGRES_USER="cabinet"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_DATABASE_PASSWORD"
DATABASE_URL="postgresql://cabinet:CHANGE_ME_STRONG_DATABASE_PASSWORD@db:5432/cabinet?schema=public"

# Cabinet public URL
APP_URL="https://cabinet.alekseevvp.site"
ALLOWED_ORIGINS="https://cabinet.alekseevvp.site"

# Generate fresh values on the server:
# openssl rand -hex 32
JWT_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL"
HEALTHCHECK_TOKEN="CHANGE_ME_GENERATE_WITH_OPENSSL"

# Email verification. Must send real email in production.
EMAIL_VERIFICATION_WEBHOOK_URL="CHANGE_ME_REAL_EMAIL_WEBHOOK_URL"
EMAIL_VERIFICATION_WEBHOOK_SECRET=""

# Remnawave Panel API
REMNAWAVE_BASE_URL="https://admin.alekseevvp.site"
REMNAWAVE_TOKEN="CHANGE_ME_ROTATED_REMNAWAVE_API_TOKEN"
REMNAWAVE_INTERNAL_SQUAD_UUIDS="f6dd100e-317d-43a1-a7d8-899411d4a841"

# Optional old remnashop read-only database access
REMNASHOP_DATABASE_URL=""
REMNASHOP_DATABASE_SSL="true"

# YooKassa production keys
YOOKASSA_SHOP_ID="1384241"
YOOKASSA_SECRET_KEY="CHANGE_ME_LIVE_YOOKASSA_SECRET_KEY"
YOOKASSA_WEBHOOK_URL="https://cabinet.alekseevvp.site/api/webhook/yookassa"
YOOKASSA_WEBHOOK_ALLOWED_IPS=""

# Telegram is optional. Fill only if old Telegram subscription transfer is needed.
TELEGRAM_CLIENT_ID=""
TELEGRAM_CLIENT_SECRET=""
TELEGRAM_BOT_USERNAME="alekseevVP_bot"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_NOTIFY_CHAT_ID=""
