# --- БД ---
DATABASE_URL="postgresql://cabinet:cabinet@localhost:5432/cabinet?schema=public&connection_limit=10&pool_timeout=20"

# --- Next.js ---
# Сгенерируй: openssl rand -hex 32
JWT_SECRET="change-me-to-a-random-32-byte-hex-string"
# Публичный URL кабинета. Используется для return_url ЮKassa и проверок Origin.
APP_URL="http://localhost:3000"
# Дополнительные разрешённые origins через запятую, если есть reverse proxy / tunnel.
ALLOWED_ORIGINS=""
# Доверять x-forwarded-* / x-real-ip только если reverse proxy очищает внешние заголовки.
TRUSTED_PROXY_HEADERS="false"
# Опциональный токен для глубокой проверки /api/health с доступом к БД.
HEALTHCHECK_TOKEN=""
# Email для тестовой отправки со страницы "Система".
SYSTEM_HEALTH_EMAIL_TO=""
# В Docker на сервере каталог бэкапов монтируется в /backups только на чтение.
SYSTEM_HEALTH_BACKUP_DIR="/backups"
SYSTEM_HEALTH_BACKUP_MAX_AGE_HOURS="48"
# Логи приложения в Docker stdout/stderr: debug | info | warn | error.
APP_LOG_LEVEL="info"
# true включает app-level request-log без cookie и секретов.
APP_REQUEST_LOGS="true"
# --- Sentry error tracking ---
# Публичный DSN проекта Sentry. Если пусто, SDK не отправляет события.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0"
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE="0"
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE="0"
# Для upload source maps в CI/CD.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
# Broadcast worker: 0 = один batch на запуск, >0 = постоянный цикл.
BROADCAST_WORKER_INTERVAL_SECONDS="0"
BROADCAST_WORKER_BATCH_SIZE="50"
BROADCAST_WORKER_MAX_ATTEMPTS="3"
# Если пусто, используется JWT_SECRET. В production можно задать отдельный секрет.
BROADCAST_UPLOAD_SIGNING_SECRET=""
BROADCAST_UPLOAD_ALLOW_UNSIGNED_LEGACY="false"
# Срок хранения служебных логов для npm run cleanup:retention.
AUDIT_LOG_RETENTION_DAYS="365"
NOTIFICATION_LOG_RETENTION_DAYS="180"
SYNC_EVENT_RETENTION_DAYS="180"

# --- Email verification ---
# Webhook, который реально отправляет письмо. На него уйдёт JSON: to, subject, text, html.
# Если пусто, в dev-режиме ссылка подтверждения выводится в консоль сервера.
EMAIL_VERIFICATION_WEBHOOK_URL=""
# Опциональный Bearer token для webhook-а отправки писем.
EMAIL_VERIFICATION_WEBHOOK_SECRET=""

# --- Remnawave Panel API ---
# Базовый URL твоей remnawave-панели (БЕЗ trailing slash)
REMNAWAVE_BASE_URL="https://panel.example.com"
# JWT-токен из админки Remnawave → API Tokens
REMNAWAVE_TOKEN="CHANGE_ME_REMNAWAVE_API_TOKEN"
# UUID внутренних squads, которые нужно назначать пользователю при выдаче подписки.
# Можно один UUID или несколько через запятую.
REMNAWAVE_INTERNAL_SQUAD_UUIDS=""

# --- Remnashop DB sync ---
# Read-only PostgreSQL connection string к базе remnashop.
REMNASHOP_DATABASE_URL=""
# false | true | no-verify
REMNASHOP_DATABASE_SSL="false"
REMNASHOP_API_URL=""
REMNASHOP_CATALOG_SYNC_INTERVAL_SECONDS="300"
REMNASHOP_USERS_SYNC_INTERVAL_SECONDS="300"
REMNASHOP_USER_SUBSCRIPTION_SYNC_STALE_SECONDS="300"
REMNASHOP_REVERSE_SYNC_BATCH_SIZE="25"
REMNASHOP_REVERSE_SYNC_LOOKBACK_DAYS="14"

# --- Referrals ---
# Сколько дней добавить пригласившему после первой платной покупки приглашенного.
REFERRAL_BONUS_DAYS="7"

# --- Gift box ---
BONUS_BOX_ENABLED="true"
BONUS_BOX_RUB_PER_ATTEMPT="300"
BONUS_BOX_MIN_ATTEMPTS_PER_PAYMENT="1"
BONUS_BOX_MAX_ATTEMPTS_PER_PAYMENT="10"
BONUS_BOX_ATTEMPT_TTL_DAYS="30"
BONUS_BOX_WEEKLY_ENABLED="true"
BONUS_BOX_WEEKLY_DAY="5"
BONUS_BOX_WEEKLY_ATTEMPTS="1"
BONUS_BOX_WEEKLY_MAX_BALANCE="3"
BONUS_BOX_REFERRER_ATTEMPTS="2"
BONUS_BOX_REFERRED_ATTEMPTS="1"
BONUS_BOX_PROMO_EXPIRES_IN_DAYS="7"
BONUS_BOX_ECONOMY_GUARD_ENABLED="true"
BONUS_BOX_RARE_COOLDOWN_OPENINGS="2"
BONUS_BOX_EPIC_COOLDOWN_OPENINGS="8"
BONUS_BOX_LEGENDARY_COOLDOWN_OPENINGS="30"
BONUS_BOX_EPIC_MIN_OPENINGS="4"
BONUS_BOX_LEGENDARY_MIN_OPENINGS="12"

# --- ЮKassa ---
# Тестовые ключи: https://yookassa.ru/my/shop/first-test
YOOKASSA_SHOP_ID="000000"
YOOKASSA_SECRET_KEY="CHANGE_ME_YOOKASSA_SECRET_KEY"
# URL для webhook-а (должен быть доступен из интернета; для локала — ngrok)
YOOKASSA_WEBHOOK_URL="http://localhost:3000/api/webhook/yookassa"
# Опционально: список IP/CIDR ЮKassa через запятую. Пусто = не проверять IP.
YOOKASSA_WEBHOOK_ALLOWED_IPS=""

# --- Telegram ---
# Новый Telegram Web Login / OIDC из BotFather -> Bot Settings -> Web Login.
TELEGRAM_CLIENT_ID=""
TELEGRAM_CLIENT_SECRET=""
# Legacy Login Widget fallback.
TELEGRAM_BOT_USERNAME=""
# Required for Telegram Mini App automatic authentication and legacy widget verification.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_NOTIFY_CHAT_ID=""
# По умолчанию технические Telegram-аккаунты не сливаются с email-аккаунтами без step-up.
TELEGRAM_MINIAPP_AUTO_MERGE_TECHNICAL="false"
