# --- БД ---
DATABASE_URL="postgresql://cabinet:cabinet@localhost:5432/cabinet?schema=public"

# --- Next.js ---
# Сгенерируй: openssl rand -hex 32
JWT_SECRET="change-me-to-a-random-32-byte-hex-string"
# Публичный URL кабинета. Используется для return_url ЮKassa и проверок Origin.
APP_URL="http://localhost:3000"
# Дополнительные разрешённые origins через запятую, если есть reverse proxy / tunnel.
ALLOWED_ORIGINS=""
# Опциональный токен для глубокой проверки /api/health с доступом к БД.
HEALTHCHECK_TOKEN=""

# --- Email verification ---
# Webhook, который реально отправляет письмо. На него уйдёт JSON: to, subject, text, html.
# Если пусто, в dev-режиме ссылка подтверждения выводится в консоль сервера.
EMAIL_VERIFICATION_WEBHOOK_URL=""
# Опциональный Bearer token для webhook-а отправки писем.
EMAIL_VERIFICATION_WEBHOOK_SECRET=""

# --- Remnawave Panel API ---
# Базовый URL твоей remnawave-панели (БЕЗ trailing slash)
REMNAWAVE_BASE_URL="https://panel.example.com"
# JWT-токен из админки Remnawave → API Tokens
REMNAWAVE_TOKEN="CHANGE_ME_REMNAWAVE_API_TOKEN"
# UUID внутренних squads, которые нужно назначать пользователю при выдаче подписки.
# Можно один UUID или несколько через запятую.
REMNAWAVE_INTERNAL_SQUAD_UUIDS=""

# --- Remnashop DB sync ---
# Read-only PostgreSQL connection string к базе remnashop.
REMNASHOP_DATABASE_URL=""
# false | true | no-verify
REMNASHOP_DATABASE_SSL="false"

# --- Referrals ---
# Сколько дней добавить пригласившему после первой платной покупки приглашенного.
REFERRAL_BONUS_DAYS="7"

# --- ЮKassa ---
# Тестовые ключи: https://yookassa.ru/my/shop/first-test
YOOKASSA_SHOP_ID="000000"
YOOKASSA_SECRET_KEY="CHANGE_ME_YOOKASSA_SECRET_KEY"
# URL для webhook-а (должен быть доступен из интернета; для локала — ngrok)
YOOKASSA_WEBHOOK_URL="http://localhost:3000/api/webhook/yookassa"
# Опционально: список IP/CIDR ЮKassa через запятую. Пусто = не проверять IP.
YOOKASSA_WEBHOOK_ALLOWED_IPS=""

# --- Telegram ---
# Новый Telegram Web Login / OIDC из BotFather -> Bot Settings -> Web Login.
TELEGRAM_CLIENT_ID=""
TELEGRAM_CLIENT_SECRET=""
# Legacy Login Widget fallback.
TELEGRAM_BOT_USERNAME=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_NOTIFY_CHAT_ID=""
