// Prisma schema для личного кабинета Remnawave
// Datasource: PostgreSQL
// БД хранит локальный профиль пользователя (email/пароль/тариф)
// и ссылку на его профиль в Remnawave Panel (remnawaveUuid / remnawaveShortUuid).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------
// 1. Тарифы
// ----------------------------------------------------------------------
// Это то, что пользователь видит на /plans. Цена в копейках (int)
// во избежание float-ошибок. durationDays = срок подписки при покупке.
// trafficLimitGb — лимит трафика в ГБ; null = безлимит.
// ----------------------------------------------------------------------
model Plan {
  id                   String           @id @default(cuid())
  name                 String // "Базовый", "PRO", "Безлимит"
  description          String?
  priceKopecks         Int // 19900 = 199 ₽
  durationDays         Int              @default(30)
  remnashopPlanId      Int? // исходный ID плана Remnashop для точной синхронизации
  trafficLimitGb       Int? // null = безлимит
  deviceLimit          Int              @default(5)
  activeInternalSquads String[]         @default([]) // UUID squads Remnawave для этого тарифа
  availability         PlanAvailability @default(ALL) // аудитория тарифа как в Remnashop
  allowedEmails        String[]         @default([]) // явный доступ для availability=ALLOWED
  allowedTelegramIds   String[]         @default([]) // Telegram ID строками, чтобы безопасно отдавать JSON
  isPromo              Boolean          @default(false) // бесплатный одноразовый ознакомительный тариф
  promoCodesEnabled    Boolean          @default(true) // можно ли применять скидочные промокоды к тарифу
  isFeatured           Boolean          @default(false) // тариф, выделенный в витрине
  featuredSlot         Int?             @unique // 1 только у одного выделенного тарифа
  isActive             Boolean          @default(true)
  sortOrder            Int              @default(0)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  payments             Payment[]
  subscriptions        Subscription[]
  promoCodePlans       PromoCodePlan[]
  trialRedemptions     TrialPlanRedemption[]
  giftCertificates     GiftCertificate[]
  welcomeBonusSettings WelcomeBonusSetting[] @relation("WelcomeTrialPlan")

  @@unique([remnashopPlanId, durationDays])
  @@index([isActive, sortOrder])
}

enum PlanAvailability {
  ALL
  NEW
  EXISTING
  INVITED
  ALLOWED
  LINK
}

// ----------------------------------------------------------------------
// 2. Пользователь ЛК
// ----------------------------------------------------------------------
// Это ЛОКАЛЬНЫЙ аккаунт для входа в ЛК. Внешний профиль в Remnawave
// создаётся при первой покупке подписки (lazy), UUID'ы храним здесь,
// чтобы не дёргать Remnawave при каждом логине.
// ----------------------------------------------------------------------
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  sessionVersion Int      @default(0)
  name           String?
  role           UserRole @default(USER)

  // Реферальная система: код пользователя и кто его пригласил.
  referralCode             String?          @unique
  referredById             String?
  referredBy               User?            @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals                User[]           @relation("UserReferrals")
  referralRewardsEarned    ReferralReward[] @relation("ReferralRewardsEarned")
  referralRewardAsReferred ReferralReward?  @relation("ReferralRewardReferred")

  // Telegram привязывается после email-регистрации. Используем для поиска
  // пользователя в remnashop и привязки старой Remnawave-подписки.
  telegramId        BigInt?   @unique
  telegramUsername  String?
  telegramLinkedAt  DateTime?
  remnashopUserId   Int?      @unique
  remnashopSyncedAt DateTime?

  // Ссылка на пользователя в Remnawave Panel. Заполняется при первой покупке.
  remnawaveUuid      String? @unique
  remnawaveShortUuid String? @unique
  remnawaveUsername  String? @unique

  // Согласия: время и редакция документа фиксируются отдельно.
  agreedToTermsAt            DateTime?
  agreedToTermsVersion       String?
  personalDataConsentAt      DateTime?
  personalDataConsentVersion String?
  emailVerifiedAt            DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  subscriptions              Subscription[]
  payments                   Payment[]
  devices                    Device[]
  supportTickets             SupportTicket[]
  supportMessages            SupportMessage[]
  promoCodeRedemptions       PromoCodeRedemption[]
  giftCertificateRedemptions GiftCertificateRedemption[]
  trialPlanRedemptions       TrialPlanRedemption[]
  emailVerificationTokens    EmailVerificationToken[]
  passwordResetTokens        PasswordResetToken[]
  oauthAccounts              OAuthAccount[]
  bonusBoxAttempts           BonusBoxAttempt[]
  bonusBoxOpenings           BonusBoxOpening[]
  bonusBoxMissionProgress    BonusBoxMissionProgress[]
  bonusBoxEventClaims        BonusBoxEventClaim[]
  bonusBoxRiskSignals        BonusBoxRiskSignal[]
  welcomeBonusRedemptions    WelcomeBonusRedemption[]
  auditLogsAuthored          AuditLog[]                  @relation("AuditLogActor")
  auditLogsTargeted          AuditLog[]                  @relation("AuditLogTarget")
  broadcastCampaigns         BroadcastCampaign[]         @relation("BroadcastCampaignAuthor")
  broadcastTemplates         BroadcastTemplate[]         @relation("BroadcastTemplateAuthor")
  notificationLogs           NotificationLog[]
  notifications              UserNotification[]
  adminNotificationReads     AdminNotificationRead[]
  revokedSessions            RevokedSession[]
  broadcastDeliveries        BroadcastDelivery[]

  @@index([email])
  @@index([role])
  @@index([remnawaveUuid])
  @@index([createdAt, id])
  @@index([referredById])
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

model FeatureSetting {
  id         String   @id @default("default")
  referrals  Boolean  @default(true)
  bonusBox   Boolean  @default(true)
  support    Boolean  @default(true)
  broadcasts Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PaymentProviderSetting {
  id                              String   @id @default("default")
  yookassaEnabled                 Boolean?
  yookassaShopId                  String?
  yookassaSecretKeyEncrypted      String?
  yookassaWebhookAllowedIps       String?
  payAnyWayEnabled                Boolean?
  payAnyWayMerchantId             String?
  payAnyWayIntegrityCodeEncrypted String?
  payAnyWayTestMode               Boolean?
  plategaEnabled                  Boolean?
  plategaMerchantId               String?
  plategaSecretEncrypted          String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

model NotificationLog {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel
  dedupeKey String
  sentAt    DateTime            @default(now())
  error     String?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channel, dedupeKey])
  @@index([userId, type, sentAt])
}

model UserNotification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  dedupeKey   String
  title       String
  body        String
  actionHref  String?
  actionLabel String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, readAt, createdAt])
  @@index([userId, type, createdAt])
}

model PersonalOfferSetting {
  id          String                @id @default(cuid())
  scenario    PersonalOfferScenario @unique
  enabled     Boolean               @default(true)
  priority    Int                   @default(0)
  eyebrow     String
  title       String
  description String
  cta         String
  href        String?
  meta        String?
  tone        PersonalOfferTone     @default(CYAN)
  promoCodeId String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  promoCode PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@index([enabled, priority])
  @@index([promoCodeId])
}

enum PersonalOfferScenario {
  NO_SUBSCRIPTION
  RETURN_PROMO
  RENEWAL_SOON
  CONNECT_DEVICE
  REFERRAL
}

enum PersonalOfferTone {
  CYAN
  EMERALD
  AMBER
  VIOLET
}

model WelcomeBonusSetting {
  id                   String           @id @default("default")
  enabled              Boolean          @default(false)
  type                 WelcomeBonusType @default(NONE)
  trialEnabled         Boolean          @default(false)
  trialPlanId          String?
  bonusAttemptsEnabled Boolean          @default(false)
  bonusAttempts        Int              @default(0)
  promoCodeEnabled     Boolean          @default(false)
  promoCodeId          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  trialPlan Plan?      @relation("WelcomeTrialPlan", fields: [trialPlanId], references: [id], onDelete: SetNull)
  promoCode PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@index([trialPlanId])
  @@index([promoCodeId])
}

model WelcomeBonusRedemption {
  id          String           @id @default(cuid())
  userId      String
  type        WelcomeBonusType
  settingId   String
  paymentId   String?
  promoCodeId String?
  metadata    Json?
  createdAt   DateTime         @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment   Payment?   @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  promoCode PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@unique([userId])
  @@index([type, createdAt])
  @@index([paymentId])
  @@index([promoCodeId])
}

enum WelcomeBonusType {
  NONE
  TRIAL_PLAN
  BONUS_BOX_ATTEMPTS
  PROMO_CODE
}

model AdminNotification {
  id          String                    @id @default(cuid())
  type        String
  severity    AdminNotificationSeverity @default(INFO)
  dedupeKey   String?                   @unique
  title       String
  body        String
  entityType  String?
  entityId    String?
  actionHref  String?
  actionLabel String?
  createdAt   DateTime                  @default(now())

  reads AdminNotificationRead[]

  @@index([type, createdAt])
  @@index([severity, createdAt])
  @@index([createdAt])
}

enum AdminNotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model AdminNotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime @default(now())

  notification AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
}

enum NotificationType {
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PAYMENT_STUCK
  SUBSCRIPTION_EXPIRING
  TRAFFIC_LIMIT
  SUPPORT_REPLY
  BONUS_GRANTED
  BROADCAST
}

enum NotificationChannel {
  TELEGRAM
  EMAIL
}

model BroadcastCampaign {
  id                   String           @id @default(cuid())
  title                String
  body                 String
  segment              BroadcastSegment
  inactiveDays         Int?
  channels             String[]         @default([])
  actionHref           String?
  actionLabel          String?
  actionOpenInTelegram Boolean          @default(false)
  imageUrl             String?
  recipients           Int              @default(0)
  inAppCount           Int              @default(0)
  telegramSent         Int              @default(0)
  telegramSkipped      Int              @default(0)
  telegramDuplicate    Int              @default(0)
  telegramFailed       Int              @default(0)
  emailSent            Int              @default(0)
  emailSkipped         Int              @default(0)
  emailDuplicate       Int              @default(0)
  emailFailed          Int              @default(0)
  limited              Boolean          @default(false)
  createdById          String?
  createdAt            DateTime         @default(now())

  createdBy  User?               @relation("BroadcastCampaignAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  deliveries BroadcastDelivery[]

  @@index([createdAt])
  @@index([createdById, createdAt])
}

enum BroadcastSegment {
  ALL
  ACTIVE
  NO_ACTIVE
  EXPIRED
  NEVER_PURCHASED
  INACTIVE_N_DAYS
}

model BroadcastDelivery {
  id         String                  @id @default(cuid())
  campaignId String
  userId     String
  payload    Json
  status     BroadcastDeliveryStatus @default(PENDING)
  attempts   Int                     @default(0)
  lastError  String?
  lockedAt   DateTime?
  sentAt     DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  campaign BroadcastCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([status, lockedAt, createdAt])
  @@index([campaignId, status])
  @@index([userId, createdAt])
}

enum BroadcastDeliveryStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

model BroadcastTemplate {
  id                   String   @id @default(cuid())
  title                String
  description          String?
  segment              String
  inactiveDays         Int?
  channels             String[] @default([])
  actionHref           String?
  actionLabel          String?
  actionOpenInTelegram Boolean  @default(false)
  imageUrl             String?
  body                 String
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  createdBy User? @relation("BroadcastTemplateAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([createdById, createdAt])
}

model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  email          String
  emailVerified  Boolean  @default(false)
  name           String?
  picture        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([provider, email])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
}

// ----------------------------------------------------------------------
// 3. Подписка (локальная сущность — дублирует важные поля из Remnawave,
// чтобы ЛК работал быстро, не дёргая Panel при каждом запросе)
// ----------------------------------------------------------------------
model Subscription {
  id     String  @id @default(cuid())
  userId String
  planId String?

  startAt  DateTime
  expireAt DateTime
  status   SubscriptionStatus @default(ACTIVE)

  // Лимит трафика на текущий период (в байтах). null = безлимит.
  trafficLimitBytes BigInt?
  // Сколько использовано за текущий период (мы денормализуем из Remnawave).
  trafficUsedBytes  BigInt   @default(0)
  // Lifetime-использование (как в Remnawave).
  lifetimeUsedBytes BigInt   @default(0)
  // Когда последний раз дёргали /api/subscription на нашей стороне.
  lastSyncedAt      DateTime @default(now())

  // Тех. флаг: в момент продления ещё раз зашли в Remnawave, чтобы получить новые ключи.
  // Чтобы не зафлэдить — используем флаг.
  pendingSync Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@index([userId, status])
  @@index([userId, status, expireAt])
  @@index([expireAt])
  @@index([pendingSync, updatedAt])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  DISABLED
  LIMITED
}

// ----------------------------------------------------------------------
// 4. Платёж
// ----------------------------------------------------------------------
// Платёж может проходить через несколько провайдеров. Наш internal ID
// используется как idempotency key и номер заказа у внешнего провайдера.
// ----------------------------------------------------------------------
model Payment {
  id             String  @id @default(cuid())
  userId         String
  subscriptionId String?
  planId         String
  promoCodeId    String?

  // Наши суммы (в копейках)
  amountKopecks         Int
  originalAmountKopecks Int?
  discountPercent       Int?
  discountKopecks       Int   @default(0)
  promoCodeSnapshot     Json?

  // Общие данные внешнего провайдера
  provider          PaymentProvider @default(YOOKASSA)
  externalPaymentId String?
  providerStatus    String?

  // Legacy-поля ЮKassa. Сохраняются для совместимости со старыми платежами.
  yookassaId      String?                @unique
  yookassaStatus  YookassaPaymentStatus?
  confirmationUrl String? // URL для редиректа пользователя

  status                    PaymentStatus @default(PENDING)
  paidAt                    DateTime?
  subscriptionProvisionedAt DateTime?
  provisioningError         String?
  remnashopSyncedAt         DateTime?
  remnashopSyncError        String?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription              Subscription?              @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan                      Plan                       @relation(fields: [planId], references: [id], onDelete: Restrict)
  promoCode                 PromoCode?                 @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  promoCodeRedemption       PromoCodeRedemption?
  trialPlanRedemption       TrialPlanRedemption?
  giftCertificateRedemption GiftCertificateRedemption?
  provisioningJob           ProvisioningJob?
  referralRewardTriggered   ReferralReward?
  welcomeBonusRedemptions   WelcomeBonusRedemption[]

  @@unique([provider, externalPaymentId])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([status])
  @@index([createdAt, id])
  @@index([status, createdAt])
  @@index([status, subscriptionProvisionedAt, createdAt])
  @@index([status, subscriptionProvisionedAt, remnashopSyncedAt, updatedAt], map: "Payment_status_subscriptionProvisionedAt_remnashopSyncedAt_upda")
  @@index([provider, status, createdAt])
  @@index([promoCodeId])
}

enum PaymentProvider {
  YOOKASSA
  PAYANYWAY
  PLATEGA
  LOCAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELED
  REFUNDED
}

enum YookassaPaymentStatus {
  pending
  waiting_for_capture
  succeeded
  canceled
}

model SyncEvent {
  id           String          @id @default(cuid())
  direction    SyncDirection
  entityType   String
  entityId     String
  operation    String
  status       SyncEventStatus @default(PENDING)
  attempts     Int             @default(0)
  lastError    String?
  nextRetryAt  DateTime?
  lastSyncedAt DateTime?
  metadata     Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([direction, entityType, entityId, operation])
  @@index([status, nextRetryAt, updatedAt])
  @@index([direction, entityType, status])
  @@index([updatedAt])
}

enum SyncDirection {
  CABINET_TO_REMNASHOP
  REMNASHOP_TO_CABINET
}

enum SyncEventStatus {
  PENDING
  SUCCEEDED
  FAILED
  SKIPPED
}

model ReferralReward {
  id                    String               @id @default(cuid())
  referrerId            String
  referredUserId        String               @unique
  triggeringPaymentId   String               @unique
  bonusDays             Int
  status                ReferralRewardStatus @default(PENDING)
  appliedSubscriptionId String?
  appliedAt             DateTime?
  lastError             String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  referrer          User    @relation("ReferralRewardsEarned", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser      User    @relation("ReferralRewardReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  triggeringPayment Payment @relation(fields: [triggeringPaymentId], references: [id], onDelete: Cascade)

  @@index([referrerId, status])
  @@index([status, createdAt])
}

enum ReferralRewardStatus {
  PENDING
  PROCESSING
  APPLIED
}

model TrialPlanRedemption {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  paymentId String   @unique
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@index([planId])
}

model ProvisioningJob {
  id          String                @id @default(cuid())
  paymentId   String                @unique
  status      ProvisioningJobStatus @default(PENDING)
  attempts    Int                   @default(0)
  nextRetryAt DateTime?
  lockedAt    DateTime?
  lastError   String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([lockedAt])
}

enum ProvisioningJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

// ----------------------------------------------------------------------
// 5. Промокоды
// ----------------------------------------------------------------------
// Промокод хранит правила скидки, а Payment сохраняет снимок скидки,
// чтобы история оплат не зависела от будущих изменений кода.
// ----------------------------------------------------------------------
model PromoCode {
  id              String            @id @default(cuid())
  code            String            @unique
  discountPercent Int
  audience        PromoCodeAudience @default(ALL)
  allowedEmails   String[]          @default([])
  isActive        Boolean           @default(true)
  startsAt        DateTime?
  expiresAt       DateTime?
  maxUses         Int?
  maxUsesPerUser  Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  payments                Payment[]
  redemptions             PromoCodeRedemption[]
  plans                   PromoCodePlan[]
  bonusBoxOpenings        BonusBoxOpening[]
  personalOfferSettings   PersonalOfferSetting[]
  welcomeBonusSettings    WelcomeBonusSetting[]
  welcomeBonusRedemptions WelcomeBonusRedemption[]

  @@index([isActive, startsAt, expiresAt])
  @@index([audience])
}

enum PromoCodeAudience {
  ALL
  NEW_USERS
  NO_ACTIVE_SUBSCRIPTION
  PERSONAL
}

model PromoCodePlan {
  promoCodeId String
  planId      String

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([promoCodeId, planId])
  @@index([planId])
}

model PromoCodeRedemption {
  id                    String                    @id @default(cuid())
  promoCodeId           String
  userId                String
  paymentId             String                    @unique
  status                PromoCodeRedemptionStatus @default(PENDING)
  codeSnapshot          String
  discountPercent       Int
  discountKopecks       Int
  originalAmountKopecks Int
  finalAmountKopecks    Int
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment   Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([promoCodeId, status])
  @@index([userId, promoCodeId, status])
}

enum PromoCodeRedemptionStatus {
  PENDING
  SUCCEEDED
  CANCELED
}

model GiftCertificate {
  id             String    @id @default(cuid())
  code           String    @unique
  planId         String
  durationDays   Int
  maxUses        Int       @default(1)
  maxUsesPerUser Int       @default(1)
  isActive       Boolean   @default(true)
  startsAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  plan        Plan                        @relation(fields: [planId], references: [id], onDelete: Restrict)
  redemptions GiftCertificateRedemption[]

  @@index([isActive, startsAt, expiresAt])
  @@index([planId])
}

model GiftCertificateRedemption {
  id                String                          @id @default(cuid())
  giftCertificateId String
  userId            String
  paymentId         String                          @unique
  status            GiftCertificateRedemptionStatus @default(SUCCEEDED)
  codeSnapshot      String
  durationDays      Int
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt

  giftCertificate GiftCertificate @relation(fields: [giftCertificateId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment         Payment         @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([giftCertificateId, status])
  @@index([userId, giftCertificateId, status])
}

enum GiftCertificateRedemptionStatus {
  SUCCEEDED
  CANCELED
}

// ----------------------------------------------------------------------
// 6. Устройства (проксируем HWID из Remnawave)
// ----------------------------------------------------------------------
// Если Remnawave выдаёт лимит устройств (hwidDeviceLimit), мы показываем
// список и позволяем отвязать. Храним локально для быстрого рендера.
// ----------------------------------------------------------------------
model Device {
  id          String   @id @default(cuid())
  userId      String
  hwid        String // device hardware id
  platform    String? // android, ios, windows...
  userAgent   String?
  ip          String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hwid])
  @@index([userId])
}

// ----------------------------------------------------------------------
// 7. Rate limit buckets
// ----------------------------------------------------------------------
// Небольшие скользящие бакеты для login/register/payment-sensitive API.
// Храним в БД, чтобы лимиты переживали рестарты и работали на нескольких
// инстансах приложения.
// ----------------------------------------------------------------------
model RateLimitBucket {
  key       String   @id
  count     Int      @default(1)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model RevokedSession {
  id        String   @id @default(cuid())
  jti       String   @unique
  userId    String?
  expiresAt DateTime
  revokedAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId, revokedAt])
}

// ----------------------------------------------------------------------
// 8. Поддержка
// ----------------------------------------------------------------------
// Встроенные обращения: пользователь пишет из кабинета, админ отвечает из
// админки. Храним счетчики непрочитанных, чтобы не требовать WebSocket.
// ----------------------------------------------------------------------
model SupportTicket {
  id               String              @id @default(cuid())
  userId           String
  subject          String
  category         String              @default("general")
  status           SupportTicketStatus @default(OPEN)
  userUnreadCount  Int                 @default(0)
  adminUnreadCount Int                 @default(1)
  lastMessageAt    DateTime            @default(now())
  closedAt         DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([userId, status, lastMessageAt])
  @@index([userId, lastMessageAt])
  @@index([status, lastMessageAt])
  @@index([adminUnreadCount])
  @@index([adminUnreadCount, lastMessageAt])
  @@index([adminUnreadCount, lastMessageAt, id])
}

model SupportMessage {
  id         String               @id @default(cuid())
  ticketId   String
  senderId   String?
  senderRole SupportMessageSender
  body       String
  createdAt  DateTime             @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User?         @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([senderId])
}

enum SupportTicketStatus {
  OPEN
  WAITING_ADMIN
  WAITING_USER
  CLOSED
}

enum SupportMessageSender {
  USER
  ADMIN
}

// ----------------------------------------------------------------------
// 9. Подарочный бокс
// ----------------------------------------------------------------------
// Пользователь получает открытия за оплату, рефералов и weekly-бонус.
// Результат выбирается сервером по весам подарков, а фронт только красиво
// анимирует горизонтальную ленту.
// ----------------------------------------------------------------------
model BonusBoxPrize {
  id                   String            @id @default(cuid())
  title                String
  description          String?
  type                 BonusBoxPrizeType
  value                Int
  weight               Int               @default(1)
  rarity               BonusBoxRarity    @default(COMMON)
  isActive             Boolean           @default(true)
  maxWins              Int?
  winsCount            Int               @default(0)
  promoExpiresInDays   Int?
  estimatedCostKopecks Int               @default(0)
  eventOnly            Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  openings BonusBoxOpening[]

  @@index([isActive, weight])
  @@index([rarity])
}

model BonusBoxSetting {
  id                      String   @id @default("default")
  pityEnabled             Boolean  @default(true)
  pityOpenings            Int      @default(10)
  showBestRecentOpening   Boolean  @default(true)
  activePromoRewardsLimit Int      @default(3)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model BonusBoxAttempt {
  id        String                @id @default(cuid())
  userId    String
  source    BonusBoxAttemptSource
  sourceKey String
  expiresAt DateTime?
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  opening BonusBoxOpening?

  @@unique([userId, source, sourceKey])
  @@index([userId, usedAt, expiresAt])
  @@index([source, sourceKey])
}

model BonusBoxMission {
  id             String              @id @default(cuid())
  title          String
  description    String?
  type           BonusBoxMissionType
  target         Int
  rewardAttempts Int
  isActive       Boolean             @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  progress BonusBoxMissionProgress[]

  @@index([isActive, startsAt, endsAt])
}

model BonusBoxMissionProgress {
  id             String    @id @default(cuid())
  missionId      String
  userId         String
  value          Int       @default(0)
  metadata       Json?
  lastProgressAt DateTime?
  completedAt    DateTime?
  claimedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  mission BonusBoxMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([missionId, userId])
  @@index([userId, claimedAt, updatedAt])
}

model BonusBoxEvent {
  id               String   @id @default(cuid())
  title            String
  description      String?
  isActive         Boolean  @default(true)
  startsAt         DateTime
  endsAt           DateTime
  attemptsPerUser  Int      @default(0)
  weightMultiplier Int      @default(2)
  prizeIds         String[] @default([])
  maxClaims        Int?
  claimsCount      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  claims   BonusBoxEventClaim[]
  openings BonusBoxOpening[]

  @@index([isActive, startsAt, endsAt])
}

model BonusBoxEventClaim {
  id              String   @id @default(cuid())
  eventId         String
  userId          String
  attemptsGranted Int
  claimedAt       DateTime @default(now())

  event BonusBoxEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId, claimedAt])
}

model BonusBoxRiskSignal {
  id         String                 @id @default(cuid())
  userId     String
  kind       BonusBoxRiskSignalKind
  keyHash    String
  score      Int
  details    Json?
  reviewedAt DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, keyHash])
  @@index([reviewedAt, score, createdAt])
  @@index([kind, keyHash, createdAt])
}

model BonusBoxOpening {
  id                    String    @id @default(cuid())
  userId                String
  attemptId             String    @unique
  prizeId               String
  prizeSnapshot         Json
  awardedSubscriptionId String?
  promoCodeId           String?
  remoteSynced          Boolean   @default(true)
  syncAttempts          Int       @default(0)
  lastSyncError         String?
  nextSyncAt            DateTime?
  expectedChance        Float     @default(0)
  expectedDistribution  Json?
  seasonalEventId       String?
  createdAt             DateTime  @default(now())

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempt       BonusBoxAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  prize         BonusBoxPrize   @relation(fields: [prizeId], references: [id], onDelete: Restrict)
  promoCode     PromoCode?      @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  seasonalEvent BonusBoxEvent?  @relation(fields: [seasonalEventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([prizeId, createdAt])
  @@index([promoCodeId])
  @@index([userId, remoteSynced, nextSyncAt])
  @@index([seasonalEventId, createdAt])
}

enum BonusBoxPrizeType {
  SUBSCRIPTION_DAYS
  TRAFFIC_GB
  PROMO_CODE_PERCENT
  BONUS_ATTEMPTS
  NO_PRIZE
}

enum BonusBoxRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum BonusBoxAttemptSource {
  PAYMENT
  WEEKLY
  REFERRAL
  MANUAL
  PRIZE
  MISSION
  SEASONAL_EVENT
}

enum BonusBoxMissionType {
  PAYMENT_COUNT
  REFERRAL_COUNT
  LOGIN_STREAK
}

enum BonusBoxRiskSignalKind {
  SHARED_FINGERPRINT
  SELF_REFERRAL
  EXCESSIVE_BALANCE
}

// ----------------------------------------------------------------------
// 10. Журнал действий
// ----------------------------------------------------------------------
// Легкий аудит админских и системных операций: кто, что и над чем сделал.
// Используем Json metadata, чтобы не плодить таблицы под каждую операцию.
// ----------------------------------------------------------------------
model AuditLog {
  id        String      @id @default(cuid())
  actorId   String?
  targetId  String?
  action    AuditAction
  message   String
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime    @default(now())

  actor  User? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  target User? @relation("AuditLogTarget", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([targetId, createdAt])
  @@index([action, createdAt])
}

enum AuditAction {
  ADMIN_PLAN_CREATED
  ADMIN_PLAN_UPDATED
  ADMIN_PLAN_DELETED
  ADMIN_PLAN_ASSIGNED
  ADMIN_ROLE_CHANGED
  ADMIN_PROFILE_UPDATED
  ADMIN_USERS_MERGED
  PERSONAL_OFFER_UPDATED
  PROMO_CODE_CREATED
  PROMO_CODE_UPDATED
  GIFT_CERTIFICATE_CREATED
  GIFT_CERTIFICATE_UPDATED
  PAYMENT_SYNCED
  ADMIN_NOTIFICATIONS_UPDATED
  ADMIN_BONUS_ATTEMPTS_GRANTED
  ADMIN_BONUS_PRIZE_CREATED
  ADMIN_BONUS_PRIZE_UPDATED
  ADMIN_BONUS_SETTINGS_UPDATED
  ADMIN_BONUS_MISSION_CREATED
  ADMIN_BONUS_MISSION_UPDATED
  ADMIN_BONUS_EVENT_CREATED
  ADMIN_BONUS_EVENT_UPDATED
  ADMIN_BONUS_RISK_REVIEWED
  ADMIN_FEATURES_UPDATED
  ADMIN_PAYMENT_PROVIDERS_UPDATED
  ADMIN_PAYMENT_PROVIDERS_RESET
  ADMIN_SUPPORT_UPDATED
  ADMIN_BROADCAST_CREATED
  ADMIN_BROADCAST_TEMPLATE_CREATED
  ADMIN_BROADCAST_TEMPLATE_DELETED
  REMNASHOP_SYNC_RUN
  SYSTEM_BACKUP_CREATED
}
