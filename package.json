{
  "name": "remnawave-cabinet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node scripts/start-standalone.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:env": "node scripts/check-env.mjs",
    "validate": "npm run lint && npm run typecheck && npm run check:env && npm run test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "node scripts/smoke.mjs",
    "worker:payments": "tsx scripts/payment-reconciler.ts",
    "worker:broadcasts": "tsx scripts/broadcast-worker.ts",
    "cleanup:retention": "tsx scripts/cleanup-retention.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.63.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "tailwind-merge": "^2.5.4",
    "tsx": "^4.23.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
